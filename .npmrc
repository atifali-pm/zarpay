# Expo + React Native monorepos need a hoisted (npm-style flat) node_modules
# layout. Metro's resolver does not traverse pnpm's symlinked store layout, so
# peer dependencies are reported as missing under the default (isolated)
# linker. Hoisted layout resolves that without sacrificing workspace linking.
node-linker=hoisted
public-hoist-pattern[]=*expo*
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=@babel/*
public-hoist-pattern[]=@types/*
