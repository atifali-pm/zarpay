# --- Database ---
DATABASE_URL="postgresql://zarpay:zarpay@localhost:5450/zarpay?schema=public"

# --- NextAuth (web sessions) ---
AUTH_SECRET="dev-secret-change-me-in-production-please-this-is-not-secure"
AUTH_TRUST_HOST=true
NEXTAUTH_URL="http://localhost:3010"

# --- Mobile JWT auth (bearer tokens for /api/* routes called from Expo) ---
AUTH_JWT_SECRET="dev-jwt-secret-change-me-32-bytes-minimum-please-for-real"
AUTH_JWT_ISSUER="zarpay"
AUTH_JWT_AUDIENCE="zarpay-mobile"
AUTH_JWT_EXPIRES_IN="30d"

# --- FX rates ---
FX_SOURCE="frankfurter"          # frankfurter | exchangerate-host
FX_SPREAD_BPS="120"              # 1.2% default spread
FX_CACHE_TTL_SECONDS="300"

# --- Fees ---
FEE_FIXED_GBP="1.99"

# --- Providers (dev defaults) ---
PAYMENT_IN_PROVIDER="dev"        # dev | stripe
PAYOUT_PROVIDER="dev"            # dev | partner
KYC_STORAGE_PROVIDER="local"     # local | s3
OTP_PROVIDER="dev"               # dev | twilio
EMAIL_PROVIDER="dev"             # dev | resend | postmark
SMS_PROVIDER="dev"               # dev | twilio

# --- Stripe (only if PAYMENT_IN_PROVIDER=stripe) ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""

# --- Email (only if EMAIL_PROVIDER=resend) ---
RESEND_API_KEY=""
EMAIL_FROM="Zarpay <no-reply@zarpay.dev>"

# --- Compliance thresholds ---
AML_SINGLE_TRANSFER_GBP="1000"
AML_DAILY_TOTAL_GBP="3000"
AML_VELOCITY_COUNT="5"
AML_VELOCITY_WINDOW_HOURS="24"
